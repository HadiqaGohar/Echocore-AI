# STT (Speech-to-Text)
# local = faster-whisper (offline, needs GPU for best performance)
# api = OpenAI Whisper API (needs OPENAI_API_KEY)
STT_MODE=local
OPENAI_API_KEY=

# LLM (AI Reply)
# gemini = Google Gemini (free tier: 1500 req/day)
# openrouter = OpenRouter (multiple models, free tier available)
# ollama = Local LLM via Ollama (offline)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# TTS (Text-to-Speech)
# local = pyttsx3 + espeak-ng (offline)
# openai = OpenAI TTS (needs OPENAI_API_KEY)
# elevenlabs = ElevenLabs (needs ELEVENLABS_API_KEY)
TTS_MODE=local
TTS_VOICE=nova
ELEVENLABS_API_KEY=

# Auth
JWT_SECRET=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./echocore.db

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
