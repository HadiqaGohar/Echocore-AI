# STT (Speech-to-Text) - FREE
# local = faster-whisper (offline, free)
# api = OpenAI Whisper API (paid)
STT_MODE=local
OPENAI_API_KEY=

# LLM (AI Reply) - FREE options available
# gemini = Google Gemini (free tier: 1500 req/day)
# ollama = Local LLM via Ollama (unlimited, free)
# openrouter = OpenRouter (some free models)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# TTS (Text-to-Speech) - FREE default
# edge = Microsoft Edge TTS (FREE, unlimited, best Hindi/Urdu support)
# pyttsx3 = Local espeak (FREE, robotic quality)
# openai = OpenAI TTS (paid)
# elevenlabs = ElevenLabs (paid)
TTS_MODE=edge
TTS_VOICE=nova
ELEVENLABS_API_KEY=

# Auth
JWT_SECRET=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./echocore.db

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
